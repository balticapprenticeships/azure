{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "4.1.0.4",
    "parameters": {
        "location": {
            "type": "string"
        },
        "bastionHostName": {
            "type": "string"
        },
        "bastionHostSku": {
            "type": "string"
        },
        "bastionHostScaleUnits": {
            "type": "int"
        },
        "bastionEnableTunneling": {
            "type": "bool"
        },
        "bastionEnableIpConnect": {
            "type": "bool"
        },
        "bastionEnableShareableLink": {
            "type": "bool"
        },
        "bastionEnableKerberos": {
            "type": "bool"
        },
        "bastionDisableCopyPaste": {
            "type": "bool"
        },
        "bastionEnableSessionRecording": {
            "type": "bool"
        },
        "enablePrivateOnlyBastion": {
            "type": "bool"
        },
        "bastionZones": {
            "type": "array"
        },
        "bastionPublicIpZones": {
            "type": "array"
        },
        "bastionPublicIpAddressName": {
            "type": "string"
        },
        "createdBy": {
            "type": "string"
        },
        "courseStartDate": {
            "type": "string"
        },
        "courseEndDay": {
            "type": "string"
        },
        "resourceGroupCleanup": {
            "type": "string"
        }
    },
    "resources": [
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2025-05-01",
            "name": "[parameters('bastionPublicIpAddressName')]",
            "location": "[parameters('location')]",
            "tags": {
                "DisplayName": "Public IP Address",
                "ResourceType": "PublicIPAddress",
                "ResourceUsage": "Bastion Host",
                "Dept": "[resourceGroup().tags['Dept']]",
                "CreatedBy": "[parameters('createdBy')]",
                "CourseDate": "[concat('WC-', parameters('courseStartDate'))]",
                "Cleanup": "[parameters('resourceGroupCleanup')]"
            },
            "properties": {
                "publicIPAllocationMethod": "Static",
                "publicIPAddressVersion": "IPv4"
            },
            "zones": "[parameters('bastionPublicIpZones')]"
        },
        {
            "type": "Microsoft.Network/bastionHosts",
            "apiVersion": "2025-05-01",
            "name": "[parameters('bastionHostName')]",
            "location": "[parameters('location')]",
            "tags": {
                "DisplayName": "Bastion Host",
                "ResourceType": "Bastion",
                "Dept": "[resourceGroup().tags['Dept']]",
                "CreatedBy": "[parameters('createdBy')]",
                "CourseDate": "[concat('WC-', parameters('courseStartDate'))]",
                "CourseEndDay": "[parameters('courseEndDay')]",
                "Cleanup": "[parameters('resourceGroupCleanup')]"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Network/publicIpAddresses', parameters('bastionPublicIpAddressName'))]"
            ],
            "sku": {
                "name": "[parameters('bastionHostSku')]"
            },
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "bastionHostIpConfig",
                        "properties": {
                            "subnet": {
                                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', concat(resourceGroup().name, '-vnet'), 'AzureBastionSubnet')]"
                            },
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIPAddress": {
                                "id": "[resourceId('Microsoft.Network/publicIPAddresses', parameters('bastionPublicIpAddressName'))]",
                                "properties": {
                                    "publicIPAllocationMethod": "Static",
                                    "publicIPAddressVersion": "IPv4"
                                }
                            }
                        }
                    }
                ],
                "scaleUnits": "[parameters('bastionHostScaleUnits')]",
                "enableTunneling": "[parameters('bastionEnableTunneling')]",
                "enableIpConnect": "[parameters('bastionEnableIpConnect')]",
                "enableShareableLink": "[parameters('bastionEnableShareableLink')]",
                "enableKerberos": "[parameters('bastionEnableKerberos')]",
                "disableCopyPaste": "[parameters('bastionDisableCopyPaste')]",
                "enableSessionRecording": "[parameters('bastionEnableSessionRecording')]",
                "enablePrivateOnlyBastion": "[parameters('enablePrivateOnlyBastion')]"
            },
            "zones": "[parameters('bastionZones')]"
        }
    ]
}