{
  "properties": {
    "displayName": "Deny VM creation without required tags",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Blocks VM creation if required tags are missing.",
    "metadata": {
      "category": "Tags"
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "anyOf": [
              {
                "field": "tags['Environment']",
                "exists": "false"
              },
              {
                "field": "tags['Owner']",
                "exists": "false"
              },
              {
                "field": "tags['CostCenter']",
                "exists": "false"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}